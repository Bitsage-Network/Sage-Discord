APIBARA_API_KEY=your-apibara-api-key-here

# =============================================================================
# PHASE 2: Reward System - NFT/POAP Minting
# =============================================================================

# Bot Starknet Account (for minting NFTs/POAPs)
# IMPORTANT: Bot needs minter role on NFT contracts
# This account will pay gas fees for all NFT/POAP mints
STARKNET_ACCOUNT_ADDRESS=0x...                    # Bot's Starknet wallet address
STARKNET_PRIVATE_KEY=0x...                        # KEEP SECRET! Bot's private key

# Achievement NFT Contract (for soulbound POAPs)
# Deploy contract: /Users/vaamx/bitsage-network/BitSage-Cairo-Smart-Contracts/src/contracts/achievement_nft.cairo
# Grant bot minter role: call set_gamification_contract(STARKNET_ACCOUNT_ADDRESS)
# Achievement types 100-199 reserved for Discord rewards
ACHIEVEMENT_NFT_ADDRESS=0x...                     # After deployment

# Notes for NFT/POAP Rewards:
# - Users must run /verify to connect their Starknet wallet
# - Bot pays gas fees for minting
# - POAPs are soulbound (non-transferable) via achievement_nft.cairo
# - External NFTs can use any ERC721 contract (admin must have minter role)
