# =============================================================================
# Sage Discord Bot Configuration
# =============================================================================
# Copy this file to .env and update with your actual values

# Discord Bot Configuration
# Get your bot token from: https://discord.com/developers/applications/1456748309191590051/bot
DISCORD_BOT_TOKEN=your-bot-token-here

# Discord Application Credentials
DISCORD_APPLICATION_ID=1456748309191590051
DISCORD_PUBLIC_KEY=f9c5d1d3965c0fb4b5e0b63e1671c56c3f10118efe6442e675e3056e415fb9d6
DISCORD_CLIENT_ID=1456748309191590051
DISCORD_CLIENT_SECRET=your-client-secret-here

# Your Discord Server (Guild) ID
# Enable Developer Mode in Discord → Right-click server name → Copy Server ID
GUILD_ID=your-server-id-here

# BitSage Network Configuration
# URL to BitSage coordinator API
BITSAGE_API_URL=http://localhost:8080
# Alternative: https://api.bitsage.network (production)

# Starknet Configuration
STARKNET_NETWORK=sepolia
STARKNET_RPC_URL=https://rpc.starknet-testnet.lava.build

# Bot Behavior
# Set to "true" to register commands globally (takes up to 1 hour)
# Set to "false" to register commands only in GUILD_ID (instant)
GLOBAL_COMMANDS=false

# Logging
LOG_LEVEL=info
# Options: error, warn, info, debug

# Feature Flags
ENABLE_JOB_NOTIFICATIONS=true
ENABLE_NETWORK_STATS=true
ENABLE_WALLET_COMMANDS=true

# Job Notification Channel (optional)
# Channel ID where job completion notifications will be posted
JOB_NOTIFICATION_CHANNEL_ID=

# Network Stats Channel (optional)
# Channel ID for periodic network statistics updates
NETWORK_STATS_CHANNEL_ID=

# Update Intervals (in minutes)
NETWORK_STATS_UPDATE_INTERVAL=30
JOB_POLL_INTERVAL=5

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/sage_discord
# Example: postgresql://bitsage:mypassword@localhost:5432/sage

# =============================================================================
# Token-Gating Configuration
# =============================================================================

# Web Wallet Verification
WALLET_SIGNING_PAGE_URL=https://verify.bitsage.network
# Local development: http://localhost:3000

# Feature Flags
TG_ENABLE_ZK_PROOFS=true
TG_ENABLE_STEALTH_ADDRESSES=true
TG_ENABLE_AUDITOR_SUPPORT=true

# Cache TTLs (seconds)
TG_CACHE_TTL_BALANCE=300          # 5 minutes
TG_CACHE_TTL_REPUTATION=600       # 10 minutes
TG_CACHE_TTL_STAKE=300            # 5 minutes
TG_CACHE_TTL_RULE=3600            # 1 hour

# Role Sync
TG_ROLE_SYNC_INTERVAL=3600        # 1 hour (in seconds)
TG_ENABLE_AUTO_ROLE_SYNC=true

# Starknet Contract Addresses (Sepolia Testnet)
